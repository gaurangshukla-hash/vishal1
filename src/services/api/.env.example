# TeleOSS Environment Configuration
# Copy this file to .env and update with your actual values

# API Configuration
REACT_APP_API_URL=http://localhost:8080/api
REACT_APP_API_TIMEOUT=30000
REACT_APP_CACHE_ENABLED=true
REACT_APP_CACHE_TIME=300000

# Database Configuration (for reference - configure in Spring Boot)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=teleoss
DB_USER=root
DB_PASSWORD=your_password

# Auth Configuration
REACT_APP_AUTH_TOKEN_KEY=authToken
REACT_APP_REFRESH_TOKEN_KEY=refreshToken
REACT_APP_TOKEN_EXPIRE_TIME=3600000

# Feature Flags
REACT_APP_ENABLE_REPORTS=true
REACT_APP_ENABLE_ANALYTICS=true
REACT_APP_ENABLE_EXPORT=true

# Service Configuration
REACT_APP_ENABLE_CACHING=true
REACT_APP_RETRY_ATTEMPTS=2
REACT_APP_ENABLE_PAGINATION=true
REACT_APP_PAGE_SIZE=50
